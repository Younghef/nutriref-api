USDA_API_KEY=replace-me
USDA_BASE_URL=https://api.nal.usda.gov/fdc/v1

REDIS_URL=redis://redis:6379/0

# Testnet: X402_NETWORK=base-sepolia + X402_FACILITATOR_URL=https://x402.org/facilitator
# Mainnet: X402_NETWORK=base + X402_FACILITATOR_URL=https://api.cdp.coinbase.com
#          (mainnet also requires CDP_API_KEY_ID + CDP_API_KEY_SECRET below)
X402_NETWORK=base-sepolia
X402_RECEIVER_ADDRESS=0x0000000000000000000000000000000000000000
X402_FACILITATOR_URL=https://x402.org/facilitator

# Required ONLY for mainnet — fastapi-x402 uses these to authenticate to the
# Coinbase CDP facilitator. Not needed on testnet.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

LOG_LEVEL=INFO

# Consumer-side only — used by scripts/pay_and_call.py to make test micropayments.
# A funded Base Sepolia test wallet's PRIVATE key (distinct from the receiver above).
# The server itself never reads this. Leave unset unless running the payer script.
PAYER_PRIVATE_KEY=

