FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN pip install --no-cache-dir \
      "mcp>=1.0.0" \
      "httpx>=0.27.0" \
      "eth-account>=0.13.0" \
      "x402>=2.10.0"

COPY mcp_server ./mcp_server

ENTRYPOINT ["python", "-m", "mcp_server"]
